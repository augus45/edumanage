# Environment Variables para EduManage API

# Entorno
ENVIRONMENT=development

# Base de Datos
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/edumanage
# Para testing local sin docker, usa: postgresql+asyncpg://postgres:postgres@localhost:5432/edumanage

# Redis
REDIS_URL=redis://redis:6379/0
# Para testing local sin docker, usa: redis://localhost:6379/0

# Seguridad JWT
# Generar un SECRET_KEY seguro usando: openssl rand -hex 32
SECRET_KEY=your-secure-secret-key-goes-here
ACCESS_TOKEN_EXPIRE_MINUTES=30
ALGORITHM=HS256

# MercadoPago
MERCADOPAGO_ACCESS_TOKEN=APP_USR-1234567890-XXXXXXXX-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# CRM Mock
CRM_API_URL=http://mock-crm/api
CRM_API_KEY=mock-key-123
